# ── Frontend (public) ──────────────────────────────────────────────────────
NUXT_PUBLIC_API_BASE_URL=http://localhost:3000
NUXT_PUBLIC_KZ_TEK_URL=http://localhost
NUXT_PUBLIC_X_API_KEY=your-api-key-here
NUXT_PUBLIC_MINIO_URL=http://localhost:9000

# ── Server / Nitro ─────────────────────────────────────────────────────────
# JWT secret – đổi thành chuỗi ngẫu nhiên dài >= 32 ký tự trước khi deploy
NUXT_JWT_SECRET=xc-ticket-secret-key-change-me-in-production

# ── MySQL Database ──────────────────────────────────────────────────────────
NUXT_DB_HOST=localhost
NUXT_DB_PORT=3306
NUXT_DB_USER=root
NUXT_DB_PASSWORD=root
NUXT_DB_NAME=xc_tickets
